# ============================================================================
# Knowledge Agent - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
# Then edit .env with your actual API keys and configuration.
# NEVER commit .env to version control - it contains secrets!

# ----------------------------------------------------------------------------
# LLM Provider Configuration
# ----------------------------------------------------------------------------
LLM_PROVIDER=local
# Options: 'local', 'openai', 'anthropic', 'google'
# - local: Use local models (no API key required)
# - openai: OpenAI GPT models
# - anthropic: Anthropic Claude models
# - google: Google Gemini models

LLM_API_KEY=your_api_key_here
# Required for: openai, anthropic, google
# Get API keys from:
#   OpenAI: https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com/
#   Google: https://aistudio.google.com/app/apikey
# Leave as 'your_api_key_here' for local provider

# ----------------------------------------------------------------------------
# Embedding Model Configuration
# ----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Default: Local sentence-transformers model (no API key required)
# This model is automatically downloaded on first use
# Alternative models:
#   - sentence-transformers/all-mpnet-base-v2 (higher quality, larger)
#   - sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 (multilingual)

# ----------------------------------------------------------------------------
# Vector Store (Qdrant) Configuration
# ----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# Default: Local Qdrant instance
# For Qdrant Cloud: https://your-cluster.qdrant.io
# Run local Qdrant with Docker:
#   docker run -p 6333:6333 qdrant/qdrant

QDRANT_API_KEY=
# Leave blank for local Qdrant
# Required for Qdrant Cloud deployments
# Get from: https://cloud.qdrant.io/

# ----------------------------------------------------------------------------
# Web Search Configuration
# ----------------------------------------------------------------------------
SEARCH_API_KEY=your_tavily_key_here
# Required for external web search (CAG functionality)
# Get API key from: https://tavily.com
# Free tier: 1000 requests/month

# ----------------------------------------------------------------------------
# Web Scraping Configuration
# ----------------------------------------------------------------------------
FIRECRAWL_API_KEY=your_firecrawl_key_here
# Required for web content extraction
# Get API key from: https://firecrawl.dev
# Free tier available

# ----------------------------------------------------------------------------
# YouTube Integration (Optional)
# ----------------------------------------------------------------------------
YOUTUBE_API_KEY=your_youtube_key_here
# Optional: For YouTube thumbnail and metadata features
# Get from: https://console.cloud.google.com
# Enable YouTube Data API v3 in your project

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
DEBUG=true
# Enable debug mode for development
# Set to 'false' in production

LOG_LEVEL=INFO
# Logging verbosity
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Most verbose, shows all operations
# INFO: Standard information messages
# WARNING: Only warnings and errors
# ERROR: Only errors
# CRITICAL: Only critical errors
